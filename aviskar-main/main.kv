#:kivy 2.1.0

MDScreen:
    name: "main"
    MDFloatLayout:
        md_bg_color: 1,1,1,1
        Image:
            source:"can_logo.png"
            size_hint: .8,.8
            pos_hint: {"center_x":0.5,"center_y":0.65}
        MDLabel:
            text: "Hello!"
            font_name: "Lato"
            font_size: "23sp"
            pos_hint: {"center_y": .38}
            halign:"center"
            color: (34,34,34,255)
        MDLabel:
            text: "Hello! Best place for ordering food"
            font_name: "Lato"
            font_size: "13sp"
            size_hint_x: .85
            pos_hint: {"center_x": .5,"center_y": .3}
            halign:"center"
            color: (127,127,127,255)
        Button:
            text: "LOGIN"
            size_hint: .66, .065
            pos_hint: {"center_x": .5,"center_y": .18}
            # background_color:0,0,0,0
            font_name: "Lato"
            on_release:
                root.manager.transition.direction = "left"
                root.manager.current = "login"
            canvas.before:
                Color:
                    rgb: (52,0,231,255)
                RoundedRectangle:
                    size: self.size
                    pos: self.pos
                    radius:[5]
        Button:
            text: "SIGUP"
            size_hint: .66, .065
            pos_hint: {"center_x": .5,"center_y": .09}
            # background_color: 0,0,0,0
            font_name: "Lato"
            on_release:
                root.manager.transition.direction = "left"
                root.manager.current = "signup"
                
            canvas.before:
                Color:
                    rgb: (52,0,231,255)
                RoundedRectangle:
                    size: self.size
                    pos: self.pos
                    radius:[5]