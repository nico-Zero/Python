#:kivy 2.1.0

#:set s 200


CanvasExample5:


<CanvasExample1>:
    canvas:
        Rectangle:
            pos: self.center_x - s/2,self.center_y - s/2
            size: dp(s),dp(s)
        Ellipse:
            pos: dp(10),dp(30)
            size: dp(s/2),dp(s/3) 
        Line:
            points:(0,0,self.width/4,100,self.width/2,0, self.width*3/4,100,self.width,0)
            width:2

<CanvasExample2>:
    canvas:
        Line:
            points:(self.width/2,self.height,self.width/2,0)
        Line:
            points:(0,self.height/2,self.width,self.height/2)

<CanvasExample3>:
    canvas:
        Color: 
            rgba:1 , 0 , 0, 1
        Line:
            circle: (self.width/2,self.height/2,100) # Center_x, Center_y, radius

        Color: 
            rgba:0 , 1 , 0, .6
        Line:
            ellipse: (self.width/2,self.height/2,100,200) # Center_x, Center_y, radius_x, radius_y

        Color: 
            rgba:0 , 0 , 1, .3
        Line:
            rectangle:(self.width/2,self.height/2,400,300) # Center_x, Center_y, length, brigth.

<CanvasExample4>:
    Button:
        text:'A'
        pos: 700, 0
        on_press: root.on_button_click(not my_switch.active)
    Switch:
        id: my_switch
        pos: 600,0

<CanvasExample5>:
    canvas: